#!/usr/bin/env bash

set -eu

KV_PREFIX=refs/kv
LK_PREFIX=refs/lck

FORTY_NOUGHTS=$(printf '%040d\n' 0)

warn() {
    local msg="$1"
    >&2 echo "${msg}"
}

die() {
    local code="${1:-1}"
    local msg="$2"

    >&2 echo "${msg}"
    exit "$code"
}

with_author () {
    local name=${GIT_AUTHOR_NAME:-Git KV}
    local email=${GIT_AUTHOR_EMAIL:-kv@localhost}

    GIT_AUTHOR_NAME=${name} \
    GIT_AUTHOR_EMAIL=${email} \
    GIT_COMMITTER_NAME=${GIT_COMMITTER_NAME:-$name} \
    GIT_COMMITTER_EMAIL=${GIT_COMMITTER_EMAIL:-$email} \
    "$@"
}

# -- Ref-based locking -- #

reflock_gen () {
    printf '%s:%s:%s' "$$" "$RANDOM" "$(date -u +%Y%m%dT%H%M%SZ)" | git hash-object -w --stdin
}

reflock_try () {
    local name="$1"
    local hash
    hash="${2:-$(reflock_gen)}"

    if git update-ref "${LK_PREFIX}/${name}" "$hash" "$FORTY_NOUGHTS" 2>/dev/null; then
        printf '%s\n' "$hash"
    else
        return 1
    fi
}

reflock_wait () {
    local name="$1"
    local timeout=5
    local stop=$((SECONDS + timeout))
    local success=0
    local hash

    hash=$(printf '%s:%s:%s' "$$" "$RANDOM" "$(date -u +%Y%m%dT%H%M%SZ)" | git hash-object -w --stdin)

    while true; do
        if reflock_try "$hash"; then
            success=1
            break
        fi

        if (( SECONDS >= stop )); then
            break
        fi

        sleep 0.1
    done

    if [ "$success" = 1 ]; then
        printf '%s\n' "$hash"
    else
        return 1
    fi
}

reflock_release () {
    local name="$1"
    local hash="$2"
    git update-ref -d "${LK_PREFIX}/${name}" "$hash"
}

# -- KV Store -- #

txn_begin() {
    local ns="$1"
    local ref="${KV_PREFIX}/${ns}"

    TXN_REF="${KV_PREFIX}/${ns}"; export TXN_REF
    TXN_BASE=$(git rev-parse --verify -q "$TXN_REF" || true); export TXN_BASE
    GIT_INDEX_FILE=$(mktemp); export GIT_INDEX_FILE
    trap drop_index EXIT

    if [ -n "$TXN_BASE" ]; then
        git read-tree "$TXN_BASE"
    else
        git read-tree --empty
    fi
}

txn_commit () {
    local msg="$1"
    local base="$TXN_BASE"

    tree=$(git write-tree)
    commit=$(with_author git commit-tree "$tree" ${base:+-p "$base"} ${msg:+-m "$msg"})
    git update-ref "$TXN_REF" "$commit" "${base:-$FORTY_NOUGHTS}" 2>/dev/null

    unset TXN_BASE
    unset TXN_REF
}

kv_ref () {
    local ns="$1"
    local ref="${KV_PREFIX}/${ns}"

    if git check-ref-format "${ref}"; then
        printf '%s\n' "${ref}"
    else
        die 1 "Invalid namespace ${ns}"
    fi
}

# kv_validref () {
#     git update-ref --stdin <<EOF >/dev/null 2>&1
#         a
# EOF
# }

kv_get() {
    local ns="$1"
    local key="$2"
    local ref
    ref=$(kv_ref "$ns")

    git cat-file -p "${ref}:keys/${key}"
}

kv_set() {
    local ns="$1"
    local key="$2"
    local value="$3"

    local ref="${KV_PREFIX}/${ns}"
    local base
    local hash

    txn_begin "$ns"

    hash=$(printf '%s' "$value" | git hash-object -w --stdin)
    git update-index --add --cacheinfo "100644,${hash},keys/${key}"

    txn_commit "kv: ${key} => ${value}"
}

kv_delete() {
    local ns="$1"; shift

    txn_begin "$ns"

    for key in "$@"; do
        git update-index --force-remove "keys/${key}"
    done

    txn_commit "kv: $# keys deleted"
}

kv_clear () {
    local ns="$1"

    txn_begin "$ns"

    git read-tree --empty

    txn_commit "kv: clear"
}

kv_log () {
    local ns="$1"
    git log "${KV_PREFIX}/${ns}"
}

kv_keys() {
    local ns="$1"
    local ref="${KV_PREFIX}/${ns}"

    git ls-tree --name-only "${ref}:keys"
}

kv_values() {
    if [[ "${1:-}" == "-d" ]]; then
        delim="$2"; shift 2
    fi

    local ns="$1"; shift
    local delim='\n'
    local ref="${KV_PREFIX}/${ns}"

    git ls-tree -z --object-only "${ref}:keys" "$@" \
        | git cat-file -Z --batch= \
        | xargs -0 printf '%s'"$delim"
}


drop_index() {
    if [ -n "${GIT_INDEX_FILE:-}" ]; then
        rm -f "$GIT_INDEX_FILE"
        unset GIT_INDEX_FILE
    fi
}

# -- Worktree  -- #

wkt_id () {
    local workdir="${1:-}"
    local id
    local gitdir

    gitdir=$(git ${workdir:+-C "$workdir"} rev-parse --absolute-git-dir)

    case "$gitdir" in
        */worktrees/*)
            id=$(basename "$gitdir")
            ;;
        *)
            id=main
            ;;
    esac

    echo "$id"
}

wkt_ids () {
    local line
    while IFS= read -r -d '' line; do
        if [[ $line == "worktree "* ]]; then
            wkt_id "${line#worktree }"
        fi
    done < <(git worktree list --porcelain -z)
}

wkt_num () {
    local workdir="${1:-}"
    local id
    local num

    id=$(wkt_id "$workdir")

    num=$(kv_get worktrees "$id" 2>/dev/null || true)

    if [ -n "$num" ]; then
        echo "$num"
        return
    fi

    local assigned=()

    while IFS= read -r n; do
        if [ -n "$n" ]; then
            assigned[n]=1
        fi
    done < <(kv_keys numbers 2>/dev/null || true )

    num=0
    while [ -n "${assigned[$num]:-}" ]; do
        num=$((num+1))
    done

    kv_set numbers "$num" "$id"
    kv_set worktrees "$id" "$num"

    echo "$num"
}

wkt_show() {
    local pth="$1"
    local num

    num=$(wkt_num "$pth")

    printf '%s\t%4d\n' "$pth" "$num"
}

wkt_list () {
    for_each_worktree wkt_show | column -t -s $'\t'
}

for_each_worktree () {
    local line
    local path

    while IFS= read -r -d '' line; do
        if [[ $line == "worktree "* ]]; then
        path="${line#worktree }"
            "$@" "$path"
        fi
    done < <(git worktree list --porcelain -z)
}

wkt_orphan_ids () {
    # Args to `comm` are the columns to suppress!
    comm -23 <( kv_keys worktrees | sort ) <( wkt_ids | sort )
}

wkt_prune() {
    local orphan_ids=()
    local orphan_nums=()

    while IFS= read -r id; do
        orphan_ids+=( "$id" )
    done < <(wkt_orphan_ids)

    while IFS= read -r num; do
        orphan_nums+=( "$num" )
    done < <(kv_values worktrees "${orphan_ids[@]}")

    kv_delete worktrees "${orphan_ids[@]}"
    kv_delete numbers "${orphan_nums[@]}"
}

main_kv () {
    local cmd="$1"; shift
    case "$cmd" in
        get)
            kv_get "$@"
            ;;
        set)
            kv_set "$@"
            ;;
        log)
            kv_log "$@"
            ;;
        delete)
            kv_delete "$@"
            ;;
        keys)
            kv_keys "$@"
            ;;
        values)
            kv_values "$@"
            ;;
        get-lock)
            lock_get "$@"
            ;;
        release-lock)
            lock_release "$@"
            ;;
        *)
            echo "Usage: $0 <get|set> <namespace> <key> [value]"
            exit 1
    esac
}

main_reflock() {
        local cmd="$1"; shift
            case "$cmd" in
        try)
            reflock_try "$@"
            ;;
        wait)
            reflock_wait "$@"
            ;;
        release)
            reflock_release "$@"
            ;;
        *)
            echo "Usage: $0 <get|release> <name> ..."
            exit 1
    esac
}

main_wt () {
    local cmd="${1:-num}"
    if [ $# -gt 0 ]; then
        shift
    fi

    case "$cmd" in
        id)
            wkt_id "$@"
            ;;
        num)
            wkt_num "$@"
            ;;
        list)
            wkt_list "$@"
            ;;
        prune)
            wkt_prune "$@"
            ;;
        *)
            echo "Usage: $0 <get|set> <namespace> <key> [value]"
            exit 1
    esac
}

main () {
    local bin
    bin=$(basename "$0")

    case "$bin" in
        git-kv)
            main_kv "$@"
        ;;
        git-reflock)
            main_reflock "$@"
        ;;
        *)
            main_wt "$@"
    esac
}

main "$@"
